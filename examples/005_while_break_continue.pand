# Example 005: while + break + continue
# - `while` uses truthy/falsy conditions
# - `continue` skips to the next iteration
# - `break` exits the loop immediately

i: i32 = 0
sum: i32 = 0

while i < 10 {
    i = i + 1

    if i % 2 == 0 {
        continue
    }

    if i >= 8 {
        break
    }

    sum = sum + i
}

print("sum of odd numbers below 8:", sum)
print("done")
